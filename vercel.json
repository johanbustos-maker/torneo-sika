{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/maestros", "dest": "server.js" },
    { "src": "/api/sumar-puntos", "dest": "server.js" },
    { "src": "/registro", "dest": "/registro.html" },
    { "src": "/tv", "dest": "/tv.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
